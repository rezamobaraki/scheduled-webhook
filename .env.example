# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=timers

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Webhook delivery ─────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT=10
WEBHOOK_MAX_RETRIES=3

# ── Application ──────────────────────────────────────────────────────────────
APP_SWEEP_INTERVAL=30

