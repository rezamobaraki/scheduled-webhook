    {
      "id": "acDZ09AkWiqNbGpRKyypn",
      "type": "text",
      "x": 4499.352398088602,
      "y": 948.6985617976014,
      "width": 607.1991577148438,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
