    {
      "id": "q30I6ACTrlDVddf5WAO6m",
      "type": "text",
      "x": 2712.0430435070652,
      "y": -475.27911742867957,
      "width": 721.5989990234375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "HfPvguYP2Zj0SUORX2wdk"
      ],
      "frameId": null,
      "index": "b23",
      "roundness": null,
      "seed": 1015376869,
      "version": 1172,
      "versionNonce": 1556808421,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774904484751,
      "link": null,
      "locked": false,
      "text": "NOTICE: For this assessment I choose PostgreSQL over DynamoDB because:\n— I am not Completely hands-on on DynamoDB\n\n—  Postgres is fine for a practical first version,\n     then call out that DynamoDB becomes the safer default if massive write scale \n\n— DynamoDB is a key-value NoSQL DB that can easily scale horizontally, \n    also manage-less and built for massive write throughput\n\n— With PostgreSQL I should be careful about throughput around ~10k Task/s ",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NOTICE: For this assessment I choose PostgreSQL over DynamoDB because:\n— I am not Completely hands-on on DynamoDB\n\n—  Postgres is fine for a practical first version,\n     then call out that DynamoDB becomes the safer default if massive write scale \n\n— DynamoDB is a key-value NoSQL DB that can easily scale horizontally, \n    also manage-less and built for massive write throughput\n\n— With PostgreSQL I should be careful about throughput around ~10k Task/s ",
      "autoResize": true,
      "lineHeight": 1.25
    },
