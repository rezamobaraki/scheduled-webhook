      "seed": 127940485,
      "version": 1258,
      "versionNonce": 1843039658,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774978868960,
      "link": null,
      "locked": false,
      "text": "Failiures:\n— Visible: rate limit on URL handle in Try-Except.\n    + handle with Retries with exponential backoff\n— Invisible : worker goes down \n    + Health Check endpoint that some monitoring service will doing!\n    + Job Leasting - Distributed Lock - Redis Beside MSQ or Zookeeper\n        if SQS picked, visibility timeouts works well\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Failiures:\n— Visible: rate limit on URL handle in Try-Except.\n    + handle with Retries with exponential backoff\n— Invisible : worker goes down \n    + Health Check endpoint that some monitoring service will doing!\n    + Job Leasting - Distributed Lock - Redis Beside MSQ or Zookeeper\n        if SQS picked, visibility timeouts works well\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4nYcGlIXoJ7d0yBig0NI9",
      "type": "text",
      "x": 4120.872569466871,
      "y": 296.1518517138802,
      "width": 510.3992919921875,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "-oBbADcFMEMDYu9Ra-2aA",
        "qrN0vDtuYfG6WtKeNHkxz"
      ],
      "frameId": null,
      "index": "b8W",
      "roundness": null,
      "seed": 2110318539,
      "version": 810,
      "versionNonce": 122636394,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774978868960,
      "link": null,
      "locked": false,
      "text": "If there are a lot of write I can scale it up HZ\nand scale query service less, also it is just saving to DB\nso lightweight and fast\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If there are a lot of write I can scale it up HZ\nand scale query service less, also it is just saving to DB\nso lightweight and fast\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
